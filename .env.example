# Amazon PPC Platform Environment Variables

# Amazon Ads API Credentials
AMAZON_CLIENT_ID=your_client_id_here
AMAZON_CLIENT_SECRET=your_client_secret_here
AMAZON_REDIRECT_URI=http://localhost:3000/auth/callback
AMAZON_REFRESH_TOKEN=your_refresh_token_here

# Shared Key for Transaction Validation
# NOTE: This is a dynamically generated key unique to your developer account
# Used to validate transactions outside of your app
AMAZON_SHARED_KEY=your_shared_key_here

# API Region (NA, EU, or FE)
AMAZON_REGION=NA

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/amazon_ppc

# Redis (for queue management)
REDIS_URL=redis://localhost:6379

# Alert Configuration
ALERT_EMAIL=alerts@luxeallur.com
ALERT_SMS_NUMBER=+1234567890

# Bleeder Detection Thresholds
CRITICAL_ACOS_THRESHOLD=100
WARNING_ACOS_THRESHOLD=50
MIN_ROAS_THRESHOLD=1.0

# Optimization Settings
TARGET_ACOS=30
AUTO_BID_ADJUSTMENT=true
AUTO_NEGATIVE_KEYWORDS=false  # Requires manual approval

# Application
PORT=3000
NODE_ENV=development
