{
  "name": "amazon-ppc-platform",
  "version": "1.0.0",
  "description": "Amazon PPC Monitoring and Optimization Platform for Luxe Allur",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "weekly-maintenance": "ts-node --esm scripts/weekly-maintenance.ts",
    "launch-setup": "ts-node --esm scripts/launch-setup.ts",
    "optimize": "ts-node --esm scripts/optimize.ts",
    "scale": "ts-node --esm scripts/scale.ts",
    "harvest": "ts-node --esm scripts/harvest-search-terms.ts",
    "tacos-report": "ts-node --esm scripts/tacos-report.ts",
    "server": "ts-node src/server.ts",
    "server:dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "keywords": [
    "amazon",
    "ppc",
    "advertising",
    "optimization",
    "supplements"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Luxe Allur",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.2",
    "better-sqlite3": "^12.6.2",
    "bull": "^4.12.0",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "googleapis": "^170.1.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.3",
    "redis": "^4.6.11",
    "sqlite3": "^5.1.7",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.30",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
