# SP-API Credentials for Review Requests
# Get these from: Seller Central → Apps & Services → Develop Apps

SP_API_REFRESH_TOKEN=Atzr|...your_refresh_token...
SP_API_CLIENT_ID=amzn1.application-oa2-client...
SP_API_CLIENT_SECRET=...your_client_secret...
SP_API_REGION=na  # Options: na (North America), eu (Europe), fe (Far East)

